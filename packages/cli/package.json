{
  "name": "@blissful-infra/cli",
  "version": "1.2.0",
  "description": "CLI for blissful-infra - infrastructure that thinks for itself",
  "type": "module",
  "bin": {
    "blissful-infra": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "examples"
  ],
  "scripts": {
    "build": "tsc && cp -r examples dist/examples",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "infrastructure",
    "devops",
    "docker",
    "kubernetes"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cavanpage/blissful-infra.git",
    "directory": "packages/cli"
  },
  "homepage": "https://blissful-infra.com",
  "bugs": {
    "url": "https://github.com/cavanpage/blissful-infra/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@blissful-infra/shared": "*",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "inquirer": "^12.3.2",
    "ora": "^8.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
